# ============================================================
# .env.example — WhatsApp RAG Clean (Refrimix Core v2)
# ============================================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES REAIS
# NUNCA commite o .env real para o git
# ============================================================

# --- Refrimix Core pipeline version ---
REFRIMIX_CORE_VERSION=v2

# --- Postgres (external) ---
DATABASE_URL=postgresql://user:password@host:5432/whatsapp_rag

# --- Redis (external) ---
REDIS_URL=redis://redis:6379/0

# --- Evolution API ---
EVOLUTION_API_URL=https://your-evolution-instance.com
EVOLUTION_INSTANCE=your-instance-name
EVOLUTION_API_KEY=your-api-key

# --- Owner ---
OWNER_PHONE=5511999999999

# --- Feature flags (defaults for clean repo) ---
MINIMAL_MVP_ENABLED=1
RAG_ENABLED=0
TTS_ENABLED=0
VISION_ENABLED=0
STT_ENABLED=0
PTBR_SANITIZER_ENABLED=0
CHATTERBOX_TTS_URL=
OMNIROUTE_ENABLED=0

# --- Optional: Qdrant (used only if RAG_ENABLED=1) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hermes_hvac_rag_service_staging

# --- Optional: LLM (used only if RAG or Vision enabled) ---
MINIMAX_API_KEY=
LLM_API_BASE=https://api.minimax.chat
LLM_MODEL=MiniMax-Text-01