# --- LLM: MiniMax (primário) ---
MINIMAX_API_KEY={SECRET}
MINIMAX_BASE_URL={SECRET}
MINIMAX_MODEL={SECRET}

# --- LLM: Groq (fallback automático) ---
GROQ_API_KEY={SECRET}
GROQ_MODEL={SECRET}
GROQ_BASE_URL={SECRET}

# --- Qdrant (staging) ---
QDRANT_URL={SECRET}
