# ============================================================
# Refrimix WhatsApp RAG — Variáveis de Ambiente (contrato)
# Adicione os valores reais com: hermes-vault edit
# ============================================================

# --- LLM: MiniMax (primário) ---
MINIMAX_API_KEY={SECRET}
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# --- LLM: Groq (fallback + STT + Vision repair) ---
GROQ_API_KEY={SECRET}
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# --- Vision: HuggingFace (fallback Qwen 2.5 VL) ---
HF_TOKEN={SECRET}
LOCAL_QWEN_BASE_URL=http://127.0.0.1:8010/v1
LOCAL_QWEN_MODEL=qwen2.5-vl-7b-instruct
LOCAL_PTBR_BASE_URL=http://127.0.0.1:8211/v1
LOCAL_PTBR_MODEL=qwen2.5-7b-pt-br-instruct
PTBR_POLISH_ENABLED=0

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hermes_hvac_rag_service_staging
RAG_MIN_SCORE=0.35
VALIDATED_REPLY_MIN_SCORE=9.0
SALES_CACHE_TTL_SECONDS=2592000

# --- PostgreSQL / Prisma ---
DATABASE_URL=postgresql://evo_user:{SECRET}@192.168.15.83:5432/evolution_api

# --- Redis ---
REDIS_URL=redis://192.168.15.83:6379
HANDOFF_STATE_TTL_SECONDS=7200
HANDOFF_ALERT_TTL_SECONDS=21600

# --- Evolution API ---
EVOLUTION_API_KEY={SECRET}
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=RefrimixLead

# --- TTS: Coqui XTTS v2 (local) ---
TTS_ENGINE=omnivoice
OMNIVOICE_URL=http://127.0.0.1:8202
XTTS_URL=http://localhost:8020
TTS_VOICES_PATH=/srv/data/tts/voices

# --- Alertas ---
OWNER_PHONE=5513{SECRET}   # número WhatsApp do Will (dono Refrimix)

# --- App ---
LOG_LEVEL=info
HOST=0.0.0.0
PORT=8000
